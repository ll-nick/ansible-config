#!/usr/bin/env nu

let colors = {
    peach: (ansi '#fab387')
    blue: (ansi '#89b4fa')
    green: (ansi '#a6e3a1')
}

def component-timestamp-file [component: string] {
    let data_home = $env.XDG_DATA_HOME? | default ($env.HOME | path join .local share)
    $data_home | path join stk timestamps $"($component).txt"
}

def save-timestamp [component: string] {
    let f = component-timestamp-file $component
    $f | path dirname | mkdir $in
    date now | format date "%s" | save --force $f
}

def check-update [
    reminder_time: duration
    notify: bool
] {
    let components = ["system", "mise", "dotfiles", "tmux", "neovim", "flatpak"]

    let rows = $components | each {|c|
        let f = component-timestamp-file $c
        if ($f | path exists) {
            let last_update = open $f | str trim | into datetime --format "%s"
            let elapsed = (date now) - $last_update
            let elapsed_str = if $elapsed >= 1day {
                let days = $elapsed / 1day | math floor | into int
                if $days == 1 { "1 day ago" } else { $"($days) days ago" }
            } else {
                let hours = $elapsed / 1hr | math floor | into int
                if $hours == 1 { "1 hour ago" } else { $"($hours) hours ago" }
            }
            {component: $c, last_updated: $elapsed_str, stale: ($elapsed >= $reminder_time)}
        } else {
            {component: $c, last_updated: "never", stale: true}
        }
    }

    $rows | select component last_updated | print

    if $notify {
        let stale = $rows | where stale | get component
        if ($stale | is-not-empty) {
            if (which notify-send | is-empty) {
                print "⚠️ notify-send not found - Cannot send notification!"
            } else {
                let stale_list = $stale | str join ", "
                notify-send "System out of date" $"($stale_list) haven't been updated recently. Consider running 'stk update'."
            }
        }
    }
}

def print-section [title:string] {
    print $"\n($colors.blue)###############################################(ansi reset)"
    print $"($colors.blue)#(ansi reset)  ($colors.green)($title)(ansi reset)"
    print $"($colors.blue)###############################################(ansi reset)\n"

}

# Check when each component was last updated
#
# Prints a table showing how long ago each component was updated.
# Can optionally send a desktop notification if at least one component
# hasn't been updated in too long.
def "main check" [
    --reminder-time (-r): duration = 1wk  # Time threshold before warning
    --notify (-n)                         # Send a desktop notification
]: nothing -> nothing {
    check-update $reminder_time $notify
}


# Update your system and development tools
#
# You one-stop shop for keeping your system and tools up to date.
# Runs updates for:
# - System packages (apt, nix, pacman)
# - Packages installed via mise-en-place
# - Dotfiles via Ansible
# - Tmux plugins via Tmux Plugin Manager (TPM)
# - Neovim plugins via vim.pack
# - Flatpak packages
#
# You may update a single component or run all updates at once.
def "main update" [
    component?: string # If given, update only the specified component (system, mise, dotfiles, tmux, neovim, flatpak)
    --bump (-b) # Bump versions for version-locked components
    --yes (-y) # Assume yes for all prompts
]: nothing -> nothing {
    def confirm-step [prompt_message:string] {
        if $yes {
            return true
        }

        let response = (input $"($prompt_message) \(y/N\): " | str trim | str downcase)
        if $response =~ '^(y|yes)$' { return true }
        print "Skipping..."
        return false
    }

    def update-nixos [] {
        let flake_dir = $env.HOME | path join .config nix
        if not ($flake_dir | path exists) {
            print $"⚠️ Nix flake directory not found at ($flake_dir) - Skipping!"
            return
        }

        if ($bump) {
            cd $flake_dir
            nix flake update
            git add flake.lock
            git commit -m "Version bump"
            print "\nChanges:"
            git show
            if (confirm-step "Bumped versions. Push lock file to remote?") { git push }
        }

        if (confirm-step "Rebuild system?") {
            sudo nixos-rebuild switch --flake $flake_dir
            save-timestamp "system"
        }

        if (confirm-step "Garbage collect old NixOS generations and store paths?") {
            sudo nix-collect-garbage --delete-older-than 7d
            nix store gc
        }
    }

    def update-system [] {
        print-section "Updating System Packages 📦"

        if (which pacman | is-not-empty) {
            if (confirm-step "Proceed with update via pacman?") {
                if $yes {
                    sudo pacman -Syu --noconfirm
                } else {
                    sudo pacman -Syu
                }
                save-timestamp "system"
            }
        } else if (which apt | is-not-empty) {
            if (confirm-step "Proceed with update via apt?") {
                sudo apt update
                if $yes {
                    sudo apt upgrade --yes
                } else {
                    sudo apt upgrade
                }
                save-timestamp "system"
            }
        } else if (which nixos-rebuild | is-not-empty) {
            update-nixos
        } else {
            print "No supported package manager found!"
        }
    }

    def update-mise [] {
        print-section "Updating Mise Packages 📦"
        if (which mise | is-empty) {
            print "⚠️ mise not installed - Skipping!"
            return
        }

        if (confirm-step "Update mise packages?") {
            $env.MISE_NODE_COMPILE = false
            $env.MISE_PYTHON_COMPILE = false
            if $yes {
                mise self-update --yes
                mise upgrade --yes
            } else {
                mise self-update
                mise upgrade
            }
            save-timestamp "mise"
        }
    }

    def update-dotfiles [] {
        print-section "Updating Dotfiles 🛠️"
        if (which ansible-pull | is-empty) {
            print "⚠️ ansible-pull not installed - Skipping!"
            return
        }

        if (confirm-step "Update dotfiles via Ansible?") {
            ansible-pull -U https://github.com/ll-nick/ansible-config.git
            save-timestamp "dotfiles"
        }
    }

    def update-tmux [] {
        print-section "Updating Tmux Plugins 🔧"

        let tpm_dir = $env.HOME | path join .config tmux plugins tpm
        if not ($tpm_dir | path exists) {
            print "⚠️ Tmux Plugin Manager (TPM) Not Found - Skipping!"
            return
        }

        if (confirm-step "Update Tmux plugins?") {
            let update_command = $"($tpm_dir | path join bin update_plugins) all"
            mise x -- nu -c $update_command
            save-timestamp "tmux"
        }
    }

    def update-neovim [] {
        print-section "Updating Neovim Plugins ✨"
        if (which nvim | is-empty) {
            print "⚠️ Neovim Not Found - Skipping!"
            return
        }

        if ($bump) {
            nvim --headless -c "lua vim.pack.update(nil, { force = true })" -c "qa"
            save-timestamp "neovim"
            cd ($env.HOME | path join .config nvim)
            git add nvim-pack-lock.json
            git commit -m "Version bump"
            print "\nChanges:"
            git show
            if (confirm-step "Bumped versions. Push lock file to remote?") { git push }
            return
        }

        if (confirm-step "Restore Neovim plugins from lockfile?") {
            nvim --headless -c "lua vim.pack.update(nil, { target = 'lockfile', force = true })" -c "qa"
            save-timestamp "neovim"
        }
    }

    def update-flatpak [] {
        print-section "Updating Flatpak Packages 📦"
        if (which flatpak | is-empty) {
            print "⚠️ Flatpak not installed - Skipping!"
            return
        }

        if (confirm-step "Update all Flatpak packages?") {
            if $yes {
                flatpak update --assumeyes
            } else {
                flatpak update
            }
            save-timestamp "flatpak"
        }
    }

    def update-all [] {
        update-system
        update-mise
        update-dotfiles
        update-tmux
        update-neovim
        update-flatpak

        print-section "✅ All Updates Completed!"
    }

    match $component {
        null => update-all,
        "system" => update-system,
        "mise" => update-mise,
        "dotfiles" => update-dotfiles,
        "tmux" => update-tmux,
        "neovim" => update-neovim,
        "flatpak" => update-flatpak,
        _ => {print $"Unknown component: ($component). Valid options are: system, mise, dotfiles, tmux, neovim, flatpak."}
    }
}

# Keep you dotfile stack up to date!
#
# Refer to the subcommands on how to use this tool.
def main []: nothing -> nothing {}

